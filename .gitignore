# =========================
# Qt-specific files
# =========================

# Ignore Qt Creator files
*.autosave
*.qmlproject.user
*.qmlc
*.jsc

# Ignore MOC, RCC, and UIC generated files
moc_*.cpp
qrc_*.cpp
ui_*.h

# Ignore plugin cache
*.pluginspec
*.json

# =========================
# Deployment files
# =========================

# Ignore windeployqt output
windeployqt/

# Ignore macdeployqt output
macdeployqt/

# Ignore linuxdeployqt output
linuxdeployqt/

# =========================
# Other files
# =========================

# Ignore user-specific files
*.ini
*.cfg
*.config

# Ignore logs and crash reports
*.log
*.crash

# Ignore IDE-specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore Python cache files (if applicable)
__pycache__/
*.pyc
*.pyo

# Ignore third-party dependencies (if not part of the repo)
/third_party/
/vendor/

# Ignore environment files
.env
.env.local

